{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project timeline with tasks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "Task" }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "tasks", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A single task in a timeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "parentId": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "startDate", "endDate"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project timelines stored by ID."
    }
  }
}
